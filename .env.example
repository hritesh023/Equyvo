# Centralized Auth Server URL (REQUIRED)
# For local dev: http://localhost:3001 (via auth.acronous.com proxy)
# For production: https://auth.acronous.com
VITE_AUTH_URL=https://auth.acronous.com

# Cloudinary Configuration (REQUIRED for media uploads)
# Get these from https://cloudinary.com/console
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
